{
  "name": "ignix-ui",
  "version": "0.1.0",
  "description": "MCP tool definitions for Ignix UI CLI",
  "aiNative": true,
  "metadata": {
    "category": "ui-library",
    "framework": "react",
    "styling": "tailwind"
  },
  "tools": [
    {
      "name": "install_component",
      "description": "CRITICAL: ALWAYS use this tool to install Ignix UI components. NEVER manually create component files. This tool copies components to src/components/ui/.",
      "inputSchema": {
        "type": "object",
        "required": ["components"],
        "properties": {
          "components": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of component names to install"
          },
          "cwd": {
            "type": "string",
            "description": "Working directory to install into",
            "default": "."
          }
        }
      },
      "examples": [
        {
          "components": ["button"]
        },
        {
          "components": ["button", "card", "input"]
        }
      ],
      "execution": {
        "type": "shell",
        "command": "ignix add component {components} --yes --json --cwd {cwd}",
        "notes": "Components must be space-separated when executed."
      }
    },
    {
      "name": "list_components",
      "description": "List available Ignix UI components",
      "execution": {
        "type": "shell",
        "command": "ignix list component --json"
      }
    },
    {
      "name": "get_component",
      "description": "Get component metadata",
      "inputSchema": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "execution": {
        "type": "shell",
        "command": "ignix info {name} --json"
      }
    },
    {
      "name": "init_project",
      "description": "Initialize Ignix UI in a project using deterministic machine mode.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "cwd": {
            "type": "string",
            "description": "Working directory to initialize",
            "default": "."
          }
        }
      },
      "execution": {
        "type": "shell",
        "command": "ignix init --yes --json --cwd {cwd}"
      }
    },
    {
      "name": "install_theme",
      "description": "Install Ignix UI theme preset deterministically.",
      "inputSchema": {
        "type": "object",
        "required": ["themes"],
        "properties": {
          "themes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of theme preset names to install"
          },
          "cwd": {
            "type": "string",
            "description": "Working directory to install themes into",
            "default": "."
          }
        }
      },
      "execution": {
        "type": "shell",
        "command": "ignix add theme {themes} --yes --json --cwd {cwd}"
      }
    },
    {
      "name": "search_components",
      "description": "Search for components by keyword or category",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search term (e.g., 'form', 'navigation', 'button')"
          },
          "category": {
            "type": "string",
            "enum": ["layout", "forms", "feedback", "navigation", "data-display"],
            "description": "Filter by component category"
          }
        }
      },
      "execution": {
        "type": "shell",
        "command": "ignix list component --search {query} --category {category} --json"
      }
    },
    {
      "name": "install_with_dependencies",
      "description": "Install components and automatically resolve dependencies",
      "inputSchema": {
        "type": "object",
        "required": ["components"],
        "properties": {
          "components": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of component names to install"
          },
          "cwd": {
            "type": "string",
            "description": "Working directory",
            "default": "."
          },
          "resolveDependencies": {
            "type": "boolean",
            "description": "Automatically install component dependencies",
            "default": true
          }
        }
      },
      "execution": {
        "type": "shell",
        "command": "ignix add component {components} --with-deps --yes --json --cwd {cwd}"
      }
    },
    {
      "name": "check_compatibility",
      "description": "Check if Ignix UI is compatible with the current project",
      "execution": {
        "type": "shell",
        "command": "ignix doctor --json"
      }
    },
    {
      "name": "get_version",
      "description": "Get installed Ignix CLI version",
      "execution": {
        "type": "shell",
        "command": "ignix --version"
      }
    }
  ],
  "resources": [
    {
      "name": "component_registry",
      "uri": "file://./packages/registry/registry.json",
      "description": "Machine-readable component registry"
    },
    {
      "name": "documentation",
      "uri": "file://./llms.txt",
      "description": "AI-readable project documentation"
    }
  ],
  "capabilities": {
    "supportsNonInteractive": true,
    "requiresNetwork": true,
    "outputFormats": ["json"]
  }
}
